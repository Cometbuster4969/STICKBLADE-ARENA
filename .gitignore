# ======================================================================
# STICKBLADE ARENA — .gitignore
# Protects: secrets, local databases, user data, build artifacts, caches
# ======================================================================

# ---------------- SECRETS — never commit these ----------------
.env
.env.*
*.env
.envrc
secrets.*
*.key
*.pem
credentials*.json
service-account*.json
.netrc
.git-credentials

# ---------------- Local data / generated match output ----------------
# Arena runtime data (SQLite DB + stored replays + turn logs)
arena_data/
*.db
*.sqlite
*.sqlite3

# Generated battle logs, replays, tournaments, screenshots, recordings
battle_log_*.json
log_*.json
replays/
tournaments/
shot_*.png
joint_shot*.png
*.pid

# ---------------- Python ----------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
htmlcov/

# ---------------- Node / Next.js (stickblade-web) ----------------
node_modules/
.next/
out/
.vercel/
.turbo/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---------------- OS / editor noise ----------------
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-*

# ---------------- Misc caches / sandbox dirs ----------------
.cache/
.npm/
.config/
.arena/
nohup.out
*.log
