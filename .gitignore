# ======================================================================
# STICKBLADE ARENA — .gitignore
# Protects: secrets, local databases, user data, build artifacts, caches
# ======================================================================

# ---------------- SECRETS — never commit these ----------------
.env
.env.*
*.env
.envrc
secrets.*
*.key
*.pem
credentials*.json
service-account*.json
.netrc
.git-credentials
.aws/
.ssh/

# ---------------- Local data / generated match output ----------------
# Arena runtime data (SQLite DB + stored replays + turn logs)
arena_data/
*.db
*.sqlite
*.sqlite3

# Generated battle logs, replays, tournaments, screenshots, recordings
battle_log_*.json
log_*.json
replays/
tournaments/
shot_*.png
design_*.png
joint_shot*.png
wp_*.png
fl_*.png
*.pid
*.mp4
*.gif

# ---------------- Python ----------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
wheels/
.venv/
venv/
env/
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.ipynb_checkpoints/

# ---------------- Node / Next.js (stickblade-web) ----------------
node_modules/
.next/
out/
.vercel/
.turbo/
.swc/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---------------- OS / editor noise ----------------
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini
ehthumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-*
.spyderproject
.ropeproject

# ---------------- Misc caches / sandbox dirs ----------------
.cache/
.npm/
.config/
.arena/
nohup.out
*.log
*.tmp
tmp/
temp/
